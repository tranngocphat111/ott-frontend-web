# Local development can call the backend directly.
VITE_API_URL=http://localhost:8080/riff/api
VITE_FRONTEND_URL=http://localhost:5173
VITE_GOOGLE_CLIENT_ID=replace-with-google-client-id
VITE_LIVEKIT_URL=wss://replace-me.livekit.cloud

# Optional. Leave empty to let chat socket use the same gateway origin as VITE_API_URL.
VITE_CHAT_SOCKET_URL=

# Optional legacy media/relationship socket. Leave empty unless port 8091 is exposed with CORS/SSL.
VITE_RELATIONSHIP_SOCKET_URL=
VITE_MEDIA_SOCKET_URL=
