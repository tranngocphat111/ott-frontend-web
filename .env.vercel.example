# Vercel deploy defaults to same-origin API/socket proxy from vercel.json.
# Keep VITE_API_URL relative to avoid HTTPS -> HTTP mixed-content errors.
VITE_API_URL=/riff/api
VITE_GOOGLE_CLIENT_ID=replace-with-google-client-id
VITE_LIVEKIT_URL=wss://replace-me.livekit.cloud

# Set this only after you know the stable production Vercel/domain URL.
# Google OAuth redirect must match this exact URL plus /auth/google/callback.
VITE_FRONTEND_URL=https://riff-iuh.vercel.app

# Usually leave these empty on Vercel so chat socket uses /socket.io on the same origin.
VITE_CHAT_SOCKET_URL=
VITE_RELATIONSHIP_SOCKET_URL=
VITE_MEDIA_SOCKET_URL=

# Vercel rewrite can proxy Socket.IO polling, but WebSocket upgrade through /socket.io can fail.
# Leave empty to auto-use polling on *.vercel.app, or set "polling,websocket" when using a real HTTPS backend domain.
VITE_SOCKET_TRANSPORTS=
