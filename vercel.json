{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/riff/api/:path*",
      "destination": "http://139.59.112.104:8080/riff/api/:path*"
    },
    {
      "source": "/socket.io",
      "destination": "http://139.59.112.104:8080/socket.io"
    },
    {
      "source": "/socket.io/",
      "destination": "http://139.59.112.104:8080/socket.io/"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "http://139.59.112.104:8080/socket.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
